#!/usr/bin/env bash
#
# Run segman tests. Usage:
#   ./run-tests           # all languages
#   ./run-tests go        # one language
#   ./run-tests js
#   ./run-tests rust

set -euo pipefail

cd "$(dirname "$0")"

run_go()   { echo "== Go ==";   (cd go && go test -v); }
run_js()   { echo "== JS ==";   (cd js && node segman_test.js); }
run_rust() { echo "== Rust =="; (cd rust && cargo test -- --nocapture); }

case "${1:-all}" in
    go)   run_go ;;
    js)   run_js ;;
    rust) run_rust ;;
    all)  run_go; echo; run_js; echo; run_rust ;;
    *)    echo "usage: $0 [go|js|rust|all]"; exit 2 ;;
esac
