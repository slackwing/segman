#!/bin/bash

# Usage: ./04-context search terms...
# Example: ./04-context can you bear with me

if [ -z "$1" ]; then
    echo "Usage: $0 search terms..."
    echo "Example: $0 can you bear with me"
    exit 1
fi

SEARCH="$*"
MANUSCRIPT="manuscripts/the-wildfire.manuscript"

if [ ! -f "$MANUSCRIPT" ]; then
    echo "Error: $MANUSCRIPT not found"
    exit 1
fi

# ANSI color codes
GREEN='\033[0;32m'
BOLD='\033[1m'
RESET='\033[0m'

# Read entire manuscript preserving all formatting
TEXT=$(cat "$MANUSCRIPT")

OCCURRENCE=0
POS=0

while true; do
    # Find next occurrence of search string
    REMAINING="${TEXT:$POS}"

    # Check if search string exists in remaining text
    if [[ "$REMAINING" != *"$SEARCH"* ]]; then
        if [ $OCCURRENCE -eq 0 ]; then
            echo "No occurrences found."
        else
            echo "No more occurrences. Total found: $OCCURRENCE"
        fi
        exit 0
    fi

    # Find position of match in remaining text
    PREFIX="${REMAINING%%"$SEARCH"*}"
    MATCH_POS=$((POS + ${#PREFIX}))

    # Extract context
    BEFORE="${TEXT:0:$MATCH_POS}"
    MATCH="${TEXT:$MATCH_POS:${#SEARCH}}"
    AFTER="${TEXT:$((MATCH_POS + ${#SEARCH}))}"

    # Get 100 words before and after (split on whitespace, preserving original format)
    WORDS_BEFORE=$(echo "$BEFORE" | grep -oE '\S+' | tail -100)
    WORDS_AFTER=$(echo "$AFTER" | grep -oE '\S+' | head -100)

    # Reconstruct context by finding these words in original text
    # This is simpler: just take characters before/after and find last/first 100 words
    # Actually, let's just show raw character context

    # Find where to start showing (100 words back)
    WORD_COUNT=0
    START_POS=$MATCH_POS
    for ((i=MATCH_POS-1; i>=0; i--)); do
        CHAR="${TEXT:$i:1}"
        if [[ "$CHAR" =~ [[:space:]] ]]; then
            PREV_CHAR="${TEXT:$((i-1)):1}"
            if [[ ! "$PREV_CHAR" =~ [[:space:]] ]]; then
                ((WORD_COUNT++))
                if [ $WORD_COUNT -ge 100 ]; then
                    START_POS=$((i+1))
                    break
                fi
            fi
        fi
    done

    # Find where to end showing (100 words forward)
    WORD_COUNT=0
    END_POS=$((MATCH_POS + ${#SEARCH}))
    for ((i=MATCH_POS + ${#SEARCH}; i<${#TEXT}; i++)); do
        CHAR="${TEXT:$i:1}"
        if [[ "$CHAR" =~ [[:space:]] ]]; then
            NEXT_CHAR="${TEXT:$((i+1)):1}"
            if [[ ! "$NEXT_CHAR" =~ [[:space:]] ]] && [ $((i+1)) -lt ${#TEXT} ]; then
                ((WORD_COUNT++))
                if [ $WORD_COUNT -ge 100 ]; then
                    END_POS=$i
                    break
                fi
            fi
        fi
    done

    if [ $END_POS -ge ${#TEXT} ]; then
        END_POS=${#TEXT}
    fi

    # Display with original formatting preserved
    echo ""
    echo "=== Occurrence $((OCCURRENCE + 1)) ==="
    echo ""
    echo -n "${TEXT:$START_POS:$((MATCH_POS - START_POS))}"
    echo -ne "${GREEN}${BOLD}${MATCH}${RESET}"
    echo "${TEXT:$((MATCH_POS + ${#SEARCH})):$((END_POS - MATCH_POS - ${#SEARCH}))}"
    echo ""
    echo "---"
    echo "Press any key for next occurrence, 'q' to quit..."

    # Wait for key
    read -n 1 -s key
    if [ "$key" = "q" ]; then
        echo "Quit."
        exit 0
    fi

    # Move past this match
    POS=$((MATCH_POS + ${#SEARCH}))
    ((OCCURRENCE++))
done
